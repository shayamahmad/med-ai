# Mistral AI (RAG tutor, symptom checker) — pay per API use, ~$0.25/1M tokens (mistral-small)
MISTRAL_API_KEY=your_mistral_key_here

# Hugging Face Hub — model files, ChromaDB, PDFs (see README for costs)
HF_ASSETS_REPO=your-username/medai-assets
# HF_TOKEN=hf_...          # only for private repos
# HF_REPO_TYPE=dataset
# HF_DOWNLOAD_ON_START=0   # set to 1 to auto-download on backend startup (default: off)

# Frontend
REACT_APP_API_URL=http://localhost:8000
# On Vercel (same domain as backend): leave REACT_APP_API_URL unset or set to empty string
# 3D viewer loads GLB files via backend proxy (default). Optional overrides:
# REACT_APP_3D_MODELS_BASE=https://your-cdn.example/3d-models
# REACT_APP_HF_ASSETS_REPO=your-username/medai-assets
