{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd medai-frontend && npm ci && npm run build",
  "outputDirectory": "medai-frontend/build",
  "installCommand": "cd medai-frontend && npm ci",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/((?!static/).*)", "destination": "/index.html" }
  ]
}
